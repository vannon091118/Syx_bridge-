  "license": "MIT",
  "dependencies": {
    "axios": "1.17.0",
    "better-sqlite3": "^11.9.1",
    "dotenv": "16.3.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.4.1",
    "globals": "17.6.0",
    "sql.js": "1.14.1"
  }
}
