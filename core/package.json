{
  "name": "syx-bridge",
  "version": "0.25.0-alpha",
  "releaseVersion": "0.25.0-alpha",
  "description": "AI-powered translation bridge for Songs of Syx mods. Optimized for V71.",
  "main": "index.js",
  "scripts": {
    "warm-model": "node Translation/warm-model.js",
    "lint": "eslint . --fix",
    "test:syntax": "node scripts/check_syntax.js",
    "test:plugin-boundary": "node tests/plugin-boundary-contract.js",
    "test:e2e": "node tests/e2e_bug1_native_mode.js",
    "test:e2e-ml": "node tests/e2e_multi_language.js",
    "testline": "npm run lint && npm run consistency && npm run test:plugin-boundary && npm run test:e2e && npm run test:e2e-ml",
    "test": "npm run testline",
    "reconstruct": "echo 'reconstruct.js removed in cleanup commit 35ec46c'",
    "release": "node scripts/release.js",
    "sync": "node scripts/sync-version.js",
    "sync:dry": "node scripts/sync-version.js --dry-run",
    "fresh-readme": "node scripts/fresh-readme.js",
    "fresh-readme:dry": "node scripts/fresh-readme.js --dry-run",
    "consistency": "node scripts/check_consistency.js",
    "package": "node scripts/package.js",
    "workshop": "node GUI/workshop_export.js",
    "audit:db": "node DB/db_audit.js"
  },
  "keywords": [
    "songs-of-syx",
    "translation",
    "ai",
    "llm",
    "gemini",
    "groq"
