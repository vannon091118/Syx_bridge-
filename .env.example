# ──────────────────────────────────────────────────────────
# SyxBridge — Environment Configuration
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# Without keys: Google Translate Free + Argos (completely free)
# ──────────────────────────────────────────────────────────

# ── Optional: AI Provider API Keys ───────────────────────
# At least one key needed for production translation quality.
# Without any keys, SyxBridge falls back to free providers.

# GROQ_API_KEY=your_groq_key_here
# OPENROUTER_API_KEY=your_openrouter_key_here
# GEMINI_API_KEY=your_gemini_key_here
# NVIDIA_API_KEY=your_nvidia_key_here
# FCM_API_KEY=your_fcm_key_here
# PLAYER2_API_KEY=your_player2_key_here

# ── Optional: Local Models ───────────────────────────────
# To enable local models, set to 'true' (default: 'false')
# OLLAMA_ENABLED=false
# PLAYER2_ENABLED=false

# ── Advanced: Runtime Behavior ──────────────────────────
# PATCH_MODE_ENABLED=false        # Create separate mod folder instead of overwriting
# NATIVE_MODE=true                # Overwrite originals directly (with automatic backup)
# GRAMMAR_CHECK=true              # Enable grammar auditing in polish stage
# MAX_CONCURRENCY=5               # Max parallel API calls (default: 5)
